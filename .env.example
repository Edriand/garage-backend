# AWS CDK Environment Configuration
# 
# These variables are optional. If not set, CDK will use your AWS CLI
# default profile configuration.

# AWS Account ID (optional - defaults to AWS CLI configured account)
# CDK_DEFAULT_ACCOUNT=123456789012

# AWS Region (optional - defaults to AWS CLI configured region)
# CDK_DEFAULT_REGION=us-east-1

# Deployment Environment (dev, staging, prod)
# Used for tagging and resource naming
ENVIRONMENT=dev

# Note: Never commit actual credentials to version control
# This file serves as documentation only
